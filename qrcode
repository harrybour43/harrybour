    <style>
        /* Estilos específicos para esta página ocultar e centralizar o QR Code */
        
        body, html {
            height: 100%;
            overflow: hidden; /* Impede rolagem na página inteira */
        }

        /* Container principal para centralizar o conteúdo abaixo do cabeçalho */
        .main-qr-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: calc(100vh - var(--header-height)); /* Ocupa a altura restante da tela */
            padding-top: var(--header-height); /* Compensa o cabeçalho fixo */
            background-color: #ffffff; /* Fundo limpo solicitado */
            box-sizing: border-box;
        }

        .qr-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* SVG QR Code Responsivo */
        .qr-code-svg {
            display: block;
            shape-rendering: crispEdges;
        }

        /* Regras de Responsividade baseadas na orientação da tela */

        /* Telas Verticais (Retrato) - Ocupa 70% da LARGURA útil */
        @media (orientation: portrait) {
            .qr-code-svg {
                width: 70vw;
                height: 70vw; /* Mantém proporção quadrada */
                max-width: 90vh; /* Prevenção para telas muito altas e estreitas */
                max-height: 90vh;
            }
        }

        /* Telas Horizontais (Paisagem) - Ocupa 70% da ALTURA útil */
        @media (orientation: landscape) {
            .qr-code-svg {
                height: 70vh;
                width: 70vh; /* Mantém proporção quadrada */
                max-width: 90vw; /* Prevenção para telas muito baixas e largas */
                max-height: 90vw;
            }
        }
    </style>
</head>
